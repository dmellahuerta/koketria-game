FROM rust:1.86-alpine AS build

WORKDIR /app

RUN apk add --no-cache musl-dev openssl-dev pkgconfig

COPY Cargo.toml Cargo.lock* ./
COPY src ./src

RUN cargo build --release

FROM alpine:3.21

WORKDIR /app

RUN apk add --no-cache ca-certificates

COPY --from=build /app/target/release/backend_v2 /usr/local/bin/backend_v2

ENV LISTEN_HOST=0.0.0.0
ENV PORT=3001
ENV FRONT_PUBLIC_DIR=/front_public

EXPOSE 3001

CMD ["backend_v2"]
